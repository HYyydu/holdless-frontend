# Supabase
# VITE_* = used by the frontend (browser). Exposed in client bundle.
VITE_SUPABASE_PROJECT_ID=your-project-id
VITE_SUPABASE_PUBLISHABLE_KEY=your-publishable-key
VITE_SUPABASE_URL=your-supabase-url

# Python chat backend (Supabase + Redis state machine)
# No VITE_ prefix = server-only (Python/Node). Same project URL as above, different key.
# SUPABASE_URL = backend talks to Supabase (writes users, conversations, tasks).
# VITE_SUPABASE_URL = frontend Supabase client (auth, optional client-side queries).
SUPABASE_URL=your-supabase-url
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
REDIS_URL=redis://localhost:6379/0
PYTHON_API_PORT=8000

# OpenAI
OPENAI_API_KEY=sk-proj-...
OPENAI_REALTIME_API_URL=wss://api.openai.com/v1/realtime
OPENAI_REALTIME_MODEL=gpt-4o-realtime-preview-2024-12-17

# Google Places (optional)
GOOGLE_PLACES_API_KEY=...

# Chat server
CHAT_SERVER_PORT=3001

# Frontend API proxy target: 8000 = Python (History + state machine), 3001 = Node (OpenAI chat)
VITE_API_TARGET=8000

# Outbound calls – GPT-4o Realtime call backend
# If your call backend has NO /api/auth/signin and your app Auth page has no sign-in form:
#   – Set CALL_API_TOKEN to your backend's API key (sent as Authorization: Bearer <value>), or
#   – Set CALL_BACKEND_ALLOW_NO_AUTH=true if your backend requires no auth at all.
# Otherwise: per-user JWT from app sign-in, or fixed CALL_API_TOKEN from your backend's sign-in.
CALL_BACKEND_URL=http://localhost:4000
# CALL_API_TOKEN=your-backend-api-key-or-jwt
# CALL_BACKEND_ALLOW_NO_AUTH=true

# (Legacy) Vapi – commented out; see VAPI_LEGACY_SETTINGS.md
# VAPI_API_KEY=your-vapi-api-key
# VAPI_PHONE_NUMBER_ID=your-phone-number-id
# VAPI_SERVER_URL=https://your-ngrok-url (optional; for live transcript)

# Optional timeouts (ms): CALL_BACKEND_TIMEOUT_MS=15000  |  VAPI_TIMEOUT_MS=15000

# Twilio (reference; call backend may use its own Twilio config)
# TWILIO_PHONE_NUMBER=+17723099180
